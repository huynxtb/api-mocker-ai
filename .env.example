# Backend
PORT=4000
MONGODB_URI=mongodb://mongodb:27017/apimocker-ai
NODE_ENV=production
# Comma-separated list of allowed origins (e.g. http://localhost:4002,https://app.example.com)
CORS_ORIGINS=http://localhost:4002

# Security
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=60m
JWT_REFRESH_TTL=7d

# Frontend
FRONTEND_PORT=4002
VITE_BACKEND_URL=http://localhost:4000
